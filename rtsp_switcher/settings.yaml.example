rtmp_url: "rtmp://a.rtmp.youtube.com/live2/YOUR_STREAM_KEY"
ha_url: "ws://192.168.1.x:8123/api/websocket"
ha_token: "YOUR_LONG_LIVED_ACCESS_TOKEN"
ha_entity_id: "input_select.your_entity"
output_width: 2560
output_height: 1440
video_bitrate_kbps: 10000
output_framerate: 30
rtsp_latency_ms: 200
reconnect_delay_sec: 2
output_stall_timeout_sec: 10
startup_output_timeout_sec: 20
streams:
  - stream_name: "Camera 1"
    stream_url: "rtsp://192.168.1.x:8554/stream1"
    stream_width: 1920
    stream_height: 1080
    stream_framerate: 30
    stream_codec: "h264"
  - stream_name: "Camera 2"
    stream_url: "rtsp://192.168.1.x:8554/stream2"
    stream_width: 1920
    stream_height: 1080
    stream_framerate: 30
    stream_codec: "h264"
    stream_rotation: 180
